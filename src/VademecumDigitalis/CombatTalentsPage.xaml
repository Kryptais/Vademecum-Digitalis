<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VademecumDigitalis.CombatTalentsPage"
             Title="Kampftalente">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="Kampftalente" Style="{StaticResource HeadlineLabel}" />
            <Label Text="V1: Freitextliste. Später mit Waffenprofilen und AT/PA-Details." TextColor="{StaticResource TextSecondary}" FontSize="14" Margin="0,-8,0,4" />

            <Border Style="{StaticResource CardBorder}">
                <Editor AutoSize="TextChanges"
                        MinimumHeightRequest="420"
                        Placeholder="z. B. Schwerter 12, Raufen 8, Dolche 10"
                        Text="{Binding Kampftalente}" />
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
